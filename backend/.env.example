# Actarium Backend — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.

# ── AI (Required) ──────────────────────────────────────────────
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase (Required for persistent storage) ──────────────────
# Create free project at: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Google Cloud TTS (Optional — gTTS fallback used if absent) ──
# Leave empty to use gTTS (free, no key needed)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── App Config ─────────────────────────────────────────────────
ENVIRONMENT=development
# Update to your Vercel URL in production:
FRONTEND_URL=http://localhost:3000
SECRET_KEY=

# ── Paths (optional overrides) ─────────────────────────────────
# CHROMA_PERSIST_DIR=./chroma_db
# RAW_DATA_DIR=./data/raw
# AUDIO_DATA_DIR=./data/audio
